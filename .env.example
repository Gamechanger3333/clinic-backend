DATABASE_URL="postgresql://user:password@localhost:5432/clinicflow"

# JWT Secrets - use long random strings (min 32 chars each)
ACCESS_TOKEN_SECRET="change-this-access-token-secret-min-32-chars-long"
REFRESH_TOKEN_SECRET="change-this-refresh-token-secret-min-32-chars-long"

# Token expiry
ACCESS_TOKEN_EXPIRES_IN="15m"
REFRESH_TOKEN_EXPIRES_IN="7d"

PORT=3001
NODE_ENV=development

# CORS
FRONTEND_URL="http://localhost:3000"
